<?xml version="1.0" encoding="utf-8"?>
<!-- 
    This menu resource defines the 'My Menu' item with a submenu.
    It includes an icon and two submenu items: Image -1 and Image -2.
-->
<menu xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- 
        Main menu item 'My Menu'. 
        showAsAction="always" ensures the icon is visible in the App Bar.
    -->
    <item
        android:id="@+id/my_menu"
        android:title="My Menu"
        android:icon="@android:drawable/ic_menu_more"
        app:showAsAction="always">
        
        <!-- Submenu containing the image options -->
        <menu>
            <item
                android:id="@+id/image_1"
                android:title="Image -1" />
            <item
                android:id="@+id/image_2"
                android:title="Image -2" />
        </menu>
    </item>
</menu>